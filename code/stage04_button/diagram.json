{
  "version": 1,
  "author": "ESP32-NE555-Tutorial",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-v1", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    { "type": "wokwi-led", "id": "led1", "top": -60, "left": 230, "attrs": { "color": "red", "label": "D2" } },
    { "type": "wokwi-resistor", "id": "r1", "top": 70, "left": 200, "attrs": { "value": "330" } },
    { "type": "wokwi-pushbutton", "id": "btn1", "top": 200, "left": -150, "attrs": { "color": "green", "label": "BTN" } }
  ],
  "connections": [
    [ "esp:TX0", "$serialMonitor:RX", "", [] ],
    [ "esp:RX0", "$serialMonitor:TX", "", [] ],
    [ "esp:D2", "r1:1", "green", [ "h0" ] ],
    [ "r1:2", "led1:A", "green", [ "h0" ] ],
    [ "led1:C", "esp:GND.1", "black", [ "h0" ] ],
    [ "btn1:1.l", "esp:D32", "blue", [ "v0" ] ],
    [ "btn1:2.l", "esp:GND.2", "black", [ "v0" ] ]
  ]
}
