{
  "version": 1,
  "author": "ESP32-NE555-Tutorial",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-v1", "id": "esp",   "top":    0, "left":   0, "attrs": {} },
    { "type": "wokwi-ssd1306",         "id": "oled",  "top": -150, "left": 250, "attrs": { "i2cAddress": "0x3c" } },
    { "type": "wokwi-slide-switch",    "id": "sw1",   "top":  100, "left": 300, "attrs": {} },
    { "type": "wokwi-resistor",        "id": "rPull", "top":  220, "left": 300, "attrs": { "value": "10000" } }
  ],
  "connections": [
    [ "esp:TX0", "$serialMonitor:RX", "", [] ],
    [ "esp:RX0", "$serialMonitor:TX", "", [] ],

    [ "esp:3V3",   "oled:VIN",  "red",    [ "v0" ] ],
    [ "esp:GND.2", "oled:GND",  "black",  [ "v0" ] ],
    [ "esp:D21",   "oled:DATA", "green",  [ "v0" ] ],
    [ "esp:D22",   "oled:CLK",  "yellow", [ "v0" ] ],

    [ "esp:3V3",   "sw1:1",   "red",    [ "h0" ] ],
    [ "esp:GND.1", "sw1:3",   "black",  [ "h0" ] ],
    [ "sw1:2",     "esp:D34", "orange", [ "h0" ] ],

    [ "esp:D34",   "rPull:1",   "orange", [ "v0" ] ],
    [ "rPull:2",   "esp:GND.1", "black",  [ "v0" ] ]
  ]
}
