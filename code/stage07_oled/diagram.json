{
  "version": 1,
  "author": "ESP32-NE555-Tutorial",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-v1", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    { "type": "wokwi-ssd1306",    "id": "oled", "top": -150, "left": 250, "attrs": { "i2cAddress": "0x3c" } },

    { "type": "wokwi-ne555",      "id": "u1",   "top": 120, "left": 400, "attrs": {} },
    { "type": "wokwi-resistor",   "id": "r1",   "top":  20, "left": 400, "attrs": { "value": "10000" } },
    { "type": "wokwi-resistor",   "id": "r2",   "top":  80, "left": 520, "attrs": { "value": "68000" } },
    { "type": "wokwi-capacitor",  "id": "c1",   "top": 240, "left": 400, "attrs": { "value": "1u" } },
    { "type": "wokwi-capacitor",  "id": "c2",   "top": 240, "left": 520, "attrs": { "value": "10n" } }
  ],
  "connections": [
    [ "esp:TX0", "$serialMonitor:RX", "", [] ],
    [ "esp:RX0", "$serialMonitor:TX", "", [] ],

    [ "esp:3V3",   "oled:VCC", "red",    [ "v0" ] ],
    [ "esp:GND.2", "oled:GND", "black",  [ "v0" ] ],
    [ "esp:D21",   "oled:SDA", "green",  [ "v0" ] ],
    [ "esp:D22",   "oled:SCL", "yellow", [ "v0" ] ],

    [ "esp:3V3", "u1:VCC", "red",    [ "h0" ] ],
    [ "u1:RST",  "u1:VCC", "red",    [ "h0" ] ],
    [ "esp:GND.1", "u1:GND", "black", [ "h0" ] ],

    [ "r1:1", "u1:VCC", "red",   [ "h0" ] ],
    [ "r1:2", "u1:DIS", "green", [ "h0" ] ],
    [ "r2:1", "u1:DIS", "green", [ "h0" ] ],
    [ "r2:2", "u1:THR", "green", [ "h0" ] ],
    [ "u1:THR", "u1:TRIG", "green", [ "h0" ] ],
    [ "u1:THR", "c1:1", "green", [ "h0" ] ],
    [ "c1:2", "esp:GND.1", "black", [ "h0" ] ],
    [ "u1:CTRL", "c2:1", "green", [ "h0" ] ],
    [ "c2:2", "esp:GND.1", "black", [ "h0" ] ],

    [ "u1:OUT", "esp:D34", "orange", [ "h0" ] ]
  ]
}
